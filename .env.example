# lore-eligibility — Environment Variable Reference
#
# Copy this file to .env and fill in the values for your environment.
# The .env file is NEVER committed to version control (see .gitignore).
#
# Annotations:
#   # REQUIRED — must be set; the application will fail to start without it.
#   # OPTIONAL — has a sensible default; only override if needed.

# =============================================================================
# CORE — Required
# =============================================================================

# REQUIRED — PostgreSQL DSN. Use postgresql+asyncpg:// for async runtime.
# Example: postgresql+asyncpg://app_user:password@pgbouncer:6432/lore_eligibility  # pragma: allowlist secret
DATABASE_URL=

# OPTIONAL — used by integration tests; separate from DATABASE_URL.
# TEST_DATABASE_URL=postgresql://app_user@localhost/lore_eligibility_test

# REQUIRED — Session/HMAC secret. Minimum 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# REQUIRED — HMAC-SHA256 key for the WORM audit log chain.
# Must be a 64-character lowercase hex string (32 raw bytes).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_KEY=

# REQUIRED — Fernet key for tokenizing PII columns (HIPAA — protects the
# analytical surface from raw PII exposure). 32 url-safe base64 bytes.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=

# REQUIRED — Key used to HMAC-sign curated artifacts (e.g. exported eligibility
# snapshots, identity-resolution outputs). Must be distinct from SECRET_KEY.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ARTIFACT_SIGNING_KEY=

# =============================================================================
# DEPLOYMENT
# =============================================================================

# OPTIONAL — Deployment environment. Values: dev | staging | production
# Default: dev
# In production: OpenAPI docs (/docs, /redoc, /openapi.json) are disabled.
ENVIRONMENT=dev

# =============================================================================
# SECURITY
# =============================================================================

# OPTIONAL — Authentication mode. Values: none | jwt
# Default: jwt (secure-by-default)
# Note: AUTH_MODE=none is FORBIDDEN outside of ENVIRONMENT=dev.
#       Both staging and production reject AUTH_MODE=none at startup.
AUTH_MODE=jwt

# OPTIONAL — Artifact signing algorithm. Values: hmac | ed25519
# Default: hmac
SIGNING_MODE=hmac

# =============================================================================
# JWT (required only when AUTH_MODE=jwt)
# =============================================================================

# OPTIONAL — RS256 public key for JWT verification (PEM format).
JWT_PUBLIC_KEY=

# OPTIONAL — RS256 private key for JWT signing (PEM format).
JWT_PRIVATE_KEY=

# OPTIONAL — JWT token time-to-live in seconds. Range: 60 to 86400.
# Default: 3600 (1 hour)
JWT_TTL_SECONDS=3600

# OPTIONAL — JWT audience and issuer claims (required in production).
# JWT_AUDIENCE=
# JWT_ISSUER=

# =============================================================================
# DATA RETENTION (HIPAA / state law)
# =============================================================================

# OPTIONAL — Days to retain raw partner-feed records before automatic purge.
# Default: 2555 (7 years — HIPAA medical record retention floor).
RAW_FEED_RETENTION_DAYS=2555

# OPTIONAL — Days to retain audit log records (legal minimum: 6 years for HIPAA).
# Default: 2555 (7 years).
AUDIT_RETENTION_DAYS=2555

# OPTIONAL — Days old keys remain valid after rotation (0 = immediate revocation).
# Default: 30. Use 0 for emergency rotation.
KEY_ROTATION_GRACE_PERIOD_DAYS=30

# =============================================================================
# OBSERVABILITY
# =============================================================================

# OPTIONAL — Enable OpenTelemetry tracing and metrics export.
# Default: true
TELEMETRY_ENABLED=true

# OPTIONAL — Per-operator request rate limit (requests per minute).
# Default: 60. Range: 1-10000.
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# OPTIONAL — Maximum failed auth attempts before IP lockout.
# Default: 5.
AUTH_BRUTE_FORCE_MAX_ATTEMPTS=5

# OPTIONAL — Auth lockout duration in seconds.
# Default: 900 (15 minutes).
AUTH_BRUTE_FORCE_LOCKOUT_SECONDS=900

# OPTIONAL — Enforce TLS on PostgreSQL connections.
# Default: false. WARNING: false in ENVIRONMENT=production logs a warning.
DATABASE_TLS_ENABLED=false

# =============================================================================
# HEALTH CHECKS
# =============================================================================

# OPTIONAL — DB health check timeout in seconds (default: 3; range: 0.1-30)
HEALTH_DB_TIMEOUT_SECONDS=3

# OPTIONAL — Filesystem path for disk space check (default: /)
HEALTH_DISK_CHECK_PATH=/

# OPTIONAL — Minimum free disk space in bytes (default: 1 GiB)
DISK_FREE_THRESHOLD_BYTES=1073741824
